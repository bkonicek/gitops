{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  assignees: [
    '@bkonicek',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/kustomization.yaml/',
      ],
      matchStrings: [
        'https://github\\.com/(?<depName>.*/.*?)/releases/download/(?<currentValue>.*?)/',
      ],
      datasourceTemplate: 'github-releases',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/kustomization.yaml/',
      ],
      matchStrings: [
        'https://raw.githubusercontent.com/(?<depName>[^/]*/[^/]*)/(?<currentValue>.*?)/',
      ],
      datasourceTemplate: 'github-tags',
    },
    {
      customType: 'regex',
      description: 'ArgoCD config Helm charts',
      managerFilePatterns: [
        '/(^|/)config\\.ya?ml$/',
      ],
      excludeStrings: [
        'repoURL:\\s*oci://',
      ],
      matchStringsStrategy: 'combination',
      matchStrings: [
        'targetRevision:\\s*(?<currentValue>[^\\s]+)',
        'repoURL:\\s*(?<registryUrl>https?://[^\\s]+)',
        'chartName:\\s*(?<depName>[^\\s]+)',
      ],
      datasourceTemplate: 'helm',
    },
    {
      customType: 'regex',
      description: 'OCI Helm charts',
      managerFilePatterns: [
        '/(^|/)config\\.ya?ml$/',
      ],
      matchStringsStrategy: 'combination',
      matchStrings: [
        'repoURL:\\s*(?<registryUrl>oci://\\S+)',
        'targetRevision:\\s*(?<currentValue>v?\\d+\\.\\d+\\.\\d+)',
        'chartPath:\\s*(?<chartPath>[^\\s]+)',
        '(?:chartName|releaseName):\\s*(?<depName>[^\\s]+)',
      ],
      // fallback if neither chartName nor releaseName exists
      depNameTemplate: '{{#if depName}}{{depName}}{{else}}{{replace "^.*/" "" packageFileDir}}{{/if}}',
      datasourceTemplate: 'docker',
    },
  ],
  packageRules: [
    {
      groupName: '{{parentDir}}',
      matchPackageNames: [
        '/cert-manager/',
        '/tailscale/',
      ],
    },
    {
      matchUpdateTypes: [
        'patch',
      ],
      matchCurrentVersion: '!/^0/',
      automerge: true,
    },
  ],
  automergeType: 'branch',
  ignoreTests: true,
}
